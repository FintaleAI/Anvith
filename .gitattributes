# Ensure files that must run on Linux keep LF line endings
# even when checked out on Windows.
*.sh       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.conf     text eol=lf
hooks/*    text eol=lf
.gitignore text eol=lf

# Normalize web source to LF in the repo but let git convert on Windows checkout
*.html     text
*.css      text
*.js       text
*.svg      text
*.json     text
*.md       text

# Binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
